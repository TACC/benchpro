wget https://github.com/UIUC-PPL/charm/archive/refs/tags/v${charm_version}.tar.gz
tar -xf v${charm_version}.tar.gz
cd charm-${charm_version}
./build ChaNGa mpi-linux-x86_64 smp

export CHARM_DIR=`pwd`
cd ..

git clone git@github.com:N-BodyShop/changa.git
git clone git@github.com:N-BodyShop/utility.git
cd changa

./configure ${build_flags}
make -j${threads}

cp ChaNGa* ${install_path}
cp charmrun* ${install_path}
